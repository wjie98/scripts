#!/usr/bin/env bash

# =========================
# Configuration Section
# =========================

# Replaceable container runtime command
CONTAINER_CMD="${CONTAINER_CMD:-docker}"

# Shared container name prefix
CONTAINER_PREFIX="${CONTAINER_PREFIX:-devbox-}"

# Image prefix for interactive selection
IMAGE_PREFIX="${IMAGE_PREFIX:-devbox-}"

# Workspace path inside container
CONTAINER_WORKDIR="${CONTAINER_WORKDIR:-/workspace}"

# Preferred shell inside container
PREFERRED_SHELL="${PREFERRED_SHELL:-bash}"

# Default answer when GPU support is detected
DEFAULT_GPU_ENABLE="${DEFAULT_GPU_ENABLE:-yes}"

# Host port range for random SSH port mapping
PORT_RANGE_START="${PORT_RANGE_START:-20000}"
PORT_RANGE_END="${PORT_RANGE_END:-39999}"

# Proxy environment variables mirrored into generated helper functions.
PROXY_ENV_VARS=(
  http_proxy
  https_proxy
  all_proxy
  socks_proxy
  no_proxy
  HTTP_PROXY
  HTTPS_PROXY
  ALL_PROXY
  SOCKS_PROXY
  NO_PROXY
  GOPROXY
)

# Files or directories to sync during deploy
# Format: "source_path:target_path"
# Supported target placeholders: {{DEVBOX_HOME}}, {{DEVBOX_USER}}, {{CONTAINER_WORKDIR}}
DEPLOY_SYNC_FILES=(
  # "$HOME/.gitconfig:{{DEVBOX_HOME}}/.gitconfig"
  # "$HOME/.ssh/config:{{DEVBOX_HOME}}/.ssh/config"
  # "$HOME/project.env:{{CONTAINER_WORKDIR}}/.env"
)

# Commands to run during deploy
DEPLOY_COMMANDS=(
  # "apt-get update"
  # "apt-get install -y git vim curl"
)

# =========================
# Utility Functions Section
# =========================

set -u

info() {
  printf '[INFO] %s\n' "$*"
}

warn() {
  printf '[WARN] %s\n' "$*" >&2
}

error() {
  printf '[ERROR] %s\n' "$*" >&2
}

die() {
  error "$*"
  exit 1
}

runtime() {
  command "$CONTAINER_CMD" "$@"
}

command_exists() {
  command -v "$1" >/dev/null 2>&1
}

is_macos() {
  [ "$(uname -s 2>/dev/null || printf unknown)" = "Darwin" ]
}

ensure_runtime_available() {
  command_exists "$CONTAINER_CMD" || die "Container runtime not found: $CONTAINER_CMD"
}

canonical_path() {
  local target="$1"
  if [ -d "$target" ]; then
    (cd "$target" 2>/dev/null && pwd -P) || return 1
  else
    local dir base
    dir=$(dirname "$target") || return 1
    base=$(basename "$target") || return 1
    (cd "$dir" 2>/dev/null && printf '%s/%s\n' "$(pwd -P)" "$base") || return 1
  fi
}

is_home_dir() {
  local path="$1"
  local p h
  p=$(canonical_path "$path") || return 1
  h=$(canonical_path "$HOME") || return 1
  [ "$p" = "$h" ]
}

prompt_input() {
  local prompt="$1"
  local default_value="${2:-}"
  local answer

  if [ -n "$default_value" ]; then
    printf '%s [%s]: ' "$prompt" "$default_value" >&2
  else
    printf '%s: ' "$prompt" >&2
  fi

  IFS= read -r answer
  if [ -z "$answer" ]; then
    printf '%s\n' "$default_value"
  else
    printf '%s\n' "$answer"
  fi
}

confirm() {
  local prompt="$1"
  local default_answer="${2:-yes}"
  local answer suffix

  case "$default_answer" in
    yes|y|Y) suffix="[Y/n]" ;;
    no|n|N) suffix="[y/N]" ;;
    *) suffix="[y/n]" ;;
  esac

  while true; do
    printf '%s %s: ' "$prompt" "$suffix" >&2
    IFS= read -r answer
    if [ -z "$answer" ]; then
      answer="$default_answer"
    fi
    case "$answer" in
      y|Y|yes|YES) return 0 ;;
      n|N|no|NO) return 1 ;;
      *) warn "Please answer yes or no." ;;
    esac
  done
}

choose_from_list() {
  local title="$1"
  shift
  [ "$#" -gt 0 ] || return 1

  local i
  printf '%s\n' "$title" >&2
  i=1
  for item in "$@"; do
    printf '  %d) %s\n' "$i" "$item" >&2
    i=$((i + 1))
  done

  while true; do
    printf 'Select an item by number: ' >&2
    IFS= read -r i
    case "$i" in
      ''|*[!0-9]*) warn "Invalid number." ;;
      *)
        if [ "$i" -ge 1 ] && [ "$i" -le "$#" ]; then
          eval "printf '%s\n' \"\${$i}\""
          return 0
        fi
        warn "Number out of range."
        ;;
    esac
  done
}

read_lines_into_array() {
  local array_name="$1"
  local line

  eval "$array_name=()"
  while IFS= read -r line; do
    [ -n "$line" ] || continue
    eval "$array_name+=(\"\$line\")"
  done
}

write_proxy_helper_script() {
  local output_file="$1"
  local var value has_proxy="no"

  {
    printf '# Generated by devbox deploy\n'
    printf 'proxy_on() {\n'

    for var in "${PROXY_ENV_VARS[@]-}"; do
      eval "value=\${$var-}"
      if [ -n "${value:-}" ]; then
        has_proxy="yes"
        printf '    export %s=%s\n' "$var" "$(printf '%q' "$value")"
      fi
    done

    if [ "$has_proxy" = "no" ]; then
      printf '    :\n'
    fi

    printf '}\n\n'
    printf 'proxy_off() {\n'
    printf '    unset all_proxy http_proxy https_proxy socks_proxy no_proxy\n'
    printf '    unset ALL_PROXY HTTP_PROXY HTTPS_PROXY SOCKS_PROXY NO_PROXY GOPROXY\n'
    printf '}\n\n'
    printf 'proxy_on\n'
  } > "$output_file"
}

expand_deploy_target_path() {
  local template="$1"
  local dev_user="$2"
  local dev_home="$3"
  local expanded="$template"

  expanded=${expanded//\{\{DEVBOX_USER\}\}/$dev_user}
  expanded=${expanded//\{\{DEVBOX_HOME\}\}/$dev_home}
  expanded=${expanded//\{\{CONTAINER_WORKDIR\}\}/$CONTAINER_WORKDIR}

  printf '%s\n' "$expanded"
}

normalize_container_name() {
  local name="$1"
  case "$name" in
    "$CONTAINER_PREFIX"*) printf '%s\n' "$name" ;;
    *) printf '%s%s\n' "$CONTAINER_PREFIX" "$name" ;;
  esac
}

strip_container_prefix() {
  local name="$1"
  case "$name" in
    "$CONTAINER_PREFIX"*) printf '%s\n' "${name#"$CONTAINER_PREFIX"}" ;;
    *) printf '%s\n' "$name" ;;
  esac
}

container_exists() {
  local name="$1"
  runtime ps -a --format '{{.Names}}' 2>/dev/null | grep -Fx "$name" >/dev/null 2>&1
}

container_is_running() {
  local name="$1"
  runtime ps --format '{{.Names}}' 2>/dev/null | grep -Fx "$name" >/dev/null 2>&1
}

list_prefixed_containers() {
  runtime ps -a --format '{{.Names}}' 2>/dev/null | grep "^${CONTAINER_PREFIX}" || true
}

get_container_status() {
  local container="$1"
  local status

  status=$(runtime inspect --format '{{.State.Status}}' "$container" 2>/dev/null || true)
  [ -n "$status" ] || status="unknown"
  printf '%s\n' "$status"
}

get_container_image() {
  local container="$1"
  local image

  image=$(runtime inspect --format '{{.Config.Image}}' "$container" 2>/dev/null || true)
  printf '%s\n' "$image"
}

get_container_mount_source() {
  local container="$1"
  local mount_source

  mount_source=$(runtime inspect --format '{{range .Mounts}}{{if eq .Destination "'"${CONTAINER_WORKDIR}"'"}}{{.Source}}{{end}}{{end}}' "$container" 2>/dev/null || true)
  printf '%s\n' "$mount_source"
}

get_container_created_at() {
  local container="$1"
  local created_at

  created_at=$(runtime inspect --format '{{.Created}}' "$container" 2>/dev/null || true)
  printf '%s\n' "$created_at"
}

get_container_dev_uid_gid() {
  local container="$1"
  local uid gid

  uid=$(get_container_config_env "$container" "DEVBOX_UID")
  gid=$(get_container_config_env "$container" "DEVBOX_GID")

  if [ -n "$uid" ] && [ -n "$gid" ]; then
    printf '%s:%s\n' "$uid" "$gid"
    return 0
  fi

  if container_is_running "$container"; then
    runtime exec "$container" sh -lc '
if [ -f /etc/devbox/user.env ]; then
  . /etc/devbox/user.env
  printf "%s:%s\n" "${DEVBOX_UID:-}" "${DEVBOX_GID:-}"
fi
' 2>/dev/null || true
  fi
}

ensure_container_running() {
  local container="$1"
  local action_desc="$2"

  container_exists "$container" || die "Container does not exist: $container"

  if container_is_running "$container"; then
    return 0
  fi

  info "Container is not running. Starting it before ${action_desc}."
  runtime start "$container" >/dev/null || die "Failed to start container: $container"
}

get_container_workdir() {
  local container="$1"
  local workdir

  workdir=$(runtime inspect --format '{{.Config.WorkingDir}}' "$container" 2>/dev/null || true)
  printf '%s\n' "$workdir"
}

get_container_port_bindings() {
  local container="$1"
  local bindings

  bindings=$(runtime port "$container" 2>/dev/null || true)
  printf '%s\n' "$bindings"
}

list_prefixed_images() {
  runtime images --format '{{.Repository}}:{{.Tag}}' 2>/dev/null \
    | grep "^${IMAGE_PREFIX}" \
    | grep -v '^<none>:' \
    | grep -v ':<none>$' || true
}

resolve_container_name() {
  local raw="${1:-}"
  local containers selected
  local container_list

  if [ -n "$raw" ]; then
    normalize_container_name "$raw"
    return 0
  fi

  containers=$(list_prefixed_containers)
  [ -n "$containers" ] || die "No container found with prefix '${CONTAINER_PREFIX}'."

  read_lines_into_array container_list <<EOF
$containers
EOF

  selected=$(choose_from_list "Available containers:" "${container_list[@]}")
  [ -n "$selected" ] || die "No container selected."
  printf '%s\n' "$selected"
}

choose_image_interactively() {
  local images selected
  local image_list
  images=$(list_prefixed_images)

  [ -n "$images" ] || die "No local image found with prefix '${IMAGE_PREFIX}'. Build an image first."

  read_lines_into_array image_list <<EOF
$images
EOF

  selected=$(choose_from_list "Available images:" "${image_list[@]}")
  [ -n "$selected" ] || die "No image selected."
  printf '%s\n' "$selected"
}

runtime_supports_gpus() {
  if is_macos; then
    return 1
  fi

  runtime run --help 2>/dev/null | grep -q -- '--gpus'
}

collect_gpu_value() {
  local gpu_spec

  if ! runtime_supports_gpus; then
    return 0
  fi

  if ! confirm "GPU support detected. Attach GPUs?" "$DEFAULT_GPU_ENABLE"; then
    return 0
  fi

  gpu_spec=$(prompt_input "Enter GPU spec ('all', GPU ids like '0,1', or 'none')" "all")
  case "$gpu_spec" in
    none|NONE|"") return 0 ;;
    all) printf '%s\n' "all" ;;
    *) printf '%s\n' "device=${gpu_spec}" ;;
  esac
}

host_user_name() {
  id -un
}

host_group_name() {
  id -gn
}

host_user_uid() {
  id -u
}

host_user_gid() {
  id -g
}

resolve_login_user() {
  local create_user="$1"
  local user_name="$2"

  if [ "$create_user" = "yes" ] && [ "$user_name" != "root" ]; then
    printf '%s\n' "$user_name"
  else
    printf '%s\n' 'root'
  fi
}

is_port_in_use() {
  local port="$1"

  if command_exists ss; then
    ss -lnt 2>/dev/null | awk '{print $4}' | grep -E "[:.]${port}$" >/dev/null 2>&1 && return 0
  fi

  if command_exists netstat; then
    netstat -lnt 2>/dev/null | awk '{print $4}' | grep -E "[:.]${port}$" >/dev/null 2>&1 && return 0
  fi

  if command_exists lsof; then
    lsof -iTCP:"$port" -sTCP:LISTEN >/dev/null 2>&1 && return 0
  fi

  return 1
}

find_random_free_port() {
  local min="$PORT_RANGE_START"
  local max="$PORT_RANGE_END"
  local tries=100
  local port

  [ "$min" -lt "$max" ] || die "Invalid port range: ${min}-${max}"

  while [ "$tries" -gt 0 ]; do
    port=$((min + RANDOM % (max - min + 1)))
    if ! is_port_in_use "$port"; then
      printf '%s\n' "$port"
      return 0
    fi
    tries=$((tries - 1))
  done

  die "Failed to find a free port in range ${min}-${max}."
}

find_default_pubkey() {
  local key
  for key in \
    "$HOME/.ssh/id_ed25519.pub" \
    "$HOME/.ssh/id_rsa.pub" \
    "$HOME/.ssh/id_ecdsa.pub" \
    "$HOME/.ssh/id_dsa.pub"
  do
    [ -f "$key" ] && { printf '%s\n' "$key"; return 0; }
  done
  return 1
}

find_default_private_key() {
  local pubkey_file private_key

  pubkey_file=$(find_default_pubkey) || return 1
  private_key=${pubkey_file%.pub}
  [ -f "$private_key" ] || return 1
  printf '%s\n' "$private_key"
}

ensure_local_ssh_key() {
  find_default_pubkey >/dev/null 2>&1 || die "No SSH public key found under ~/.ssh. Create one first."
}

container_shell_exec() {
  local name="$1"
  local script="$2"

  if runtime exec "$name" sh -lc "command -v ${PREFERRED_SHELL} >/dev/null 2>&1"; then
    runtime exec "$name" "${PREFERRED_SHELL}" -lc "$script"
  else
    runtime exec "$name" sh -lc "$script"
  fi
}

copy_to_container() {
  local src="$1"
  local container="$2"
  local dst="$3"

  [ -e "$src" ] || die "Source path not found: $src"
  container_shell_exec "$container" "mkdir -p $(printf '%q' "$(dirname "$dst")")"
  runtime cp "$src" "${container}:${dst}"
}

remote_exec() {
  local target="$1"
  local port="$2"
  local script="$3"
  ssh ${REMOTE_SSH_OPTS:-} -p "$port" "$target" "sh -lc $(printf '%q' "$script")"
}

remote_copy() {
  local src="$1"
  local target="$2"
  local port="$3"
  local dst="$4"
  local remote_dst

  [ -e "$src" ] || die "Source path not found: $src"
  remote_exec "$target" "$port" "mkdir -p $(printf '%q' "$(dirname "$dst")")"
  remote_dst="${target}:$(printf '%q' "$dst")"

  if [ -d "$src" ]; then
    scp ${REMOTE_SCP_OPTS:-} -r -P "$port" "$src" "$remote_dst"
  else
    scp ${REMOTE_SCP_OPTS:-} -P "$port" "$src" "$remote_dst"
  fi
}

remote_user_name() {
  local target="$1"

  case "$target" in
    *@*) printf '%s\n' "${target%%@*}" ;;
    *) printf '%s\n' "$(id -un)" ;;
  esac
}

can_connect_remote_with_publickey() {
  local target="$1"
  local port="$2"

  ssh ${REMOTE_SSH_OPTS:-} -o BatchMode=yes -o PreferredAuthentications=publickey -o ConnectTimeout=5 -p "$port" "$target" true \
    >/dev/null 2>&1
}

can_connect_remote_with_password() {
  local target="$1"
  local port="$2"

  ssh ${REMOTE_SSH_OPTS:-} -o PreferredAuthentications=password,keyboard-interactive -o PubkeyAuthentication=no -o NumberOfPasswordPrompts=1 -p "$port" "$target" true
}

start_remote_connection_mux() {
  local target="$1"
  local port="$2"
  local control_path="$3"

  ssh -o ControlMaster=yes -o ControlPersist=600 -o ControlPath="$control_path" -o PreferredAuthentications=password,keyboard-interactive,publickey -p "$port" -fN "$target"
}

stop_remote_connection_mux() {
  local target="$1"
  local port="$2"
  local control_path="$3"

  ssh -o ControlPath="$control_path" -p "$port" -O exit "$target" >/dev/null 2>&1 || true
}

get_container_config_env() {
  local container="$1"
  local env_name="$2"
  local env_line

  env_line=$(runtime inspect --format '{{range .Config.Env}}{{println .}}{{end}}' "$container" 2>/dev/null \
    | grep -m1 "^${env_name}=" || true)

  if [ -n "$env_line" ]; then
    printf '%s\n' "${env_line#*=}"
  fi
}

get_container_runtime_user_env() {
  local container="$1"
  local env_name="$2"

  if container_is_running "$container"; then
    runtime exec "$container" env ENV_NAME="$env_name" sh -lc '
if [ -f /etc/devbox/user.env ]; then
  . /etc/devbox/user.env
  eval "value=\${${ENV_NAME}:-}"
  if [ -n "${value:-}" ]; then
    printf "%s\n" "${value}"
  fi
fi
' 2>/dev/null || true
  fi
}

get_container_env_value() {
  local container="$1"
  local env_name="$2"
  local value

  value=$(get_container_config_env "$container" "$env_name")
  if [ -z "$value" ]; then
    value=$(get_container_runtime_user_env "$container" "$env_name")
  fi

  printf '%s\n' "$value"
}

get_container_dev_user() {
  local container="$1"
  local user_name

  user_name=$(get_container_env_value "$container" "DEVBOX_USER")

  [ -n "$user_name" ] || user_name="root"
  printf '%s\n' "$user_name"
}

get_container_dev_group() {
  local container="$1"
  local group_name

  group_name=$(get_container_env_value "$container" "DEVBOX_GROUP")

  [ -n "$group_name" ] || group_name="root"
  printf '%s\n' "$group_name"
}

get_container_dev_home() {
  local container="$1"
  local user_name="$2"
  local user_home

  user_home=$(get_container_env_value "$container" "DEVBOX_HOME")

  if [ -z "$user_home" ] && container_is_running "$container"; then
    user_home=$(runtime exec "$container" getent passwd "$user_name" 2>/dev/null | cut -d: -f6 || true)
  fi

  if [ -z "$user_home" ] && [ "$user_name" = "root" ]; then
    user_home="/root"
  fi

  printf '%s\n' "$user_home"
}

get_container_ssh_port() {
  local container="$1"
  local line

  line=$(runtime port "$container" 22/tcp 2>/dev/null | head -n 1 || true)
  [ -n "$line" ] || return 1

  case "$line" in
    *:*)
      printf '%s\n' "${line##*:}"
      ;;
    *)
      return 1
      ;;
  esac
}

print_container_list_row() {
  local container="$1"
  local status ssh_port dev_user image mount_source

  status=$(get_container_status "$container")
  ssh_port=$(get_container_ssh_port "$container" || true)
  dev_user=$(get_container_dev_user "$container")
  image=$(get_container_image "$container")
  mount_source=$(get_container_mount_source "$container")

  [ -n "$ssh_port" ] || ssh_port="-"
  [ -n "$dev_user" ] || dev_user="-"
  [ -n "$image" ] || image="-"
  [ -n "$mount_source" ] || mount_source="-"

  printf '%-28s %-10s %-8s %-12s %-28s %s\n' \
    "$container" "$status" "$ssh_port" "$dev_user" "$image" "$mount_source"
}

append_pubkey_to_container() {
  local container="$1"
  local pubkey_file dev_user dev_group dev_home tmpdir tmpfile escaped_home escaped_user escaped_group

  pubkey_file=$(find_default_pubkey) || die "No SSH public key found."
  dev_user=$(get_container_dev_user "$container")
  dev_group=$(get_container_dev_group "$container")
  dev_home=$(get_container_dev_home "$container" "$dev_user")
  [ -n "$dev_home" ] || die "Failed to resolve home directory for container user: $dev_user"
  escaped_home=$(printf '%q' "$dev_home")
  escaped_user=$(printf '%q' "$dev_user")
  escaped_group=$(printf '%q' "$dev_group")

  tmpdir=$(mktemp -d) || die "Failed to create temporary directory."
  tmpfile="${tmpdir}/authorized_keys"
  cp "$pubkey_file" "$tmpfile" || {
    rm -rf "$tmpdir"
    die "Failed to prepare temporary authorized_keys file."
  }

  container_shell_exec "$container" "mkdir -p /root/.ssh ${escaped_home}/.ssh /tmp && chmod 700 /root/.ssh ${escaped_home}/.ssh"
  runtime cp "$tmpfile" "${container}:/tmp/devbox_authorized_key" || {
    rm -rf "$tmpdir"
    die "Failed to copy public key into container."
  }

  container_shell_exec "$container" "
touch /root/.ssh/authorized_keys
chmod 600 /root/.ssh/authorized_keys
grep -qxF -f /tmp/devbox_authorized_key /root/.ssh/authorized_keys || cat /tmp/devbox_authorized_key >> /root/.ssh/authorized_keys

touch ${escaped_home}/.ssh/authorized_keys
chmod 600 ${escaped_home}/.ssh/authorized_keys
grep -qxF -f /tmp/devbox_authorized_key ${escaped_home}/.ssh/authorized_keys || cat /tmp/devbox_authorized_key >> ${escaped_home}/.ssh/authorized_keys
rm -f /tmp/devbox_authorized_key
chown -R ${escaped_user}:${escaped_group} ${escaped_home}/.ssh || true
"

  rm -rf "$tmpdir"
}

restart_sshd_in_container() {
  local container="$1"

  container_shell_exec "$container" '
set -e
if command -v supervisorctl >/dev/null 2>&1; then
  supervisorctl -c /etc/supervisor/conf.d/supervisord.conf restart sshd >/dev/null 2>&1 \
    || supervisorctl -c /etc/supervisor/conf.d/supervisord.conf start sshd >/dev/null 2>&1 \
    || true
elif command -v service >/dev/null 2>&1; then
  service ssh restart >/dev/null 2>&1 || service sshd restart >/dev/null 2>&1 || true
elif command -v systemctl >/dev/null 2>&1; then
  systemctl restart ssh >/dev/null 2>&1 || systemctl restart sshd >/dev/null 2>&1 || true
elif command -v pkill >/dev/null 2>&1 && command -v sshd >/dev/null 2>&1; then
  pkill sshd >/dev/null 2>&1 || true
  mkdir -p /var/run/sshd
  sshd >/dev/null 2>&1 || true
fi
'
}

sync_env_to_container() {
  local container="$1"
  local tmpfile

  tmpfile=$(mktemp) || die "Failed to create temporary file."
  write_proxy_helper_script "$tmpfile"

  copy_to_container "$tmpfile" "$container" "/etc/profile.d/devbox_env.sh"
  rm -f "$tmpfile"
}

sync_files_to_container() {
  local container="$1"
  local mapping src dst resolved_src expanded_dst dev_user dev_home

  dev_user=$(get_container_dev_user "$container")
  dev_home=$(get_container_dev_home "$container" "$dev_user")
  [ -n "$dev_home" ] || die "Failed to resolve home directory for container user: $dev_user"

  for mapping in "${DEPLOY_SYNC_FILES[@]-}"; do
    src=${mapping%%:*}
    dst=${mapping#*:}
    eval "resolved_src=$src"
    expanded_dst=$(expand_deploy_target_path "$dst" "$dev_user" "$dev_home")
    [ -n "$resolved_src" ] || continue
    [ -n "$expanded_dst" ] || continue
    [ -e "$resolved_src" ] || { warn "Skip missing path: $resolved_src"; continue; }
    info "Copying to container: $resolved_src -> $expanded_dst"
    copy_to_container "$resolved_src" "$container" "$expanded_dst"
  done
}

run_deploy_commands_in_container() {
  local container="$1"
  local cmd

  for cmd in "${DEPLOY_COMMANDS[@]-}"; do
    [ -n "$cmd" ] || continue
    info "Running in container: $cmd"
    container_shell_exec "$container" "$cmd" || die "Deploy command failed: $cmd"
  done
}

deploy_local_container() {
  local container="$1"

  ensure_local_ssh_key

  ensure_container_running "$container" "deploying the environment"

  append_pubkey_to_container "$container"
  sync_env_to_container "$container"
  sync_files_to_container "$container"
  run_deploy_commands_in_container "$container"
  restart_sshd_in_container "$container"

  info "Local deploy completed for container: $container"
}

append_pubkey_to_remote() {
  local target="$1"
  local port="$2"
  local remote_user pubkey_file pubkey_text

  pubkey_file=$(find_default_pubkey) || die "No SSH public key found."
  pubkey_text=$(cat "$pubkey_file") || die "Failed to read SSH public key."
  remote_user=$(remote_user_name "$target")

  info "Installing SSH public key on remote host: $target"

  ssh ${REMOTE_SSH_OPTS:-} -p "$port" "$target" "mkdir -p ~/.ssh && chmod 700 ~/.ssh && touch ~/.ssh/authorized_keys && chmod 600 ~/.ssh/authorized_keys" \
    || die "Failed to prepare ~/.ssh on remote host: $target"

  ssh ${REMOTE_SSH_OPTS:-} -p "$port" "$target" \
    "grep -qxF $(printf '%q' "$pubkey_text") ~/.ssh/authorized_keys || printf '%s\n' $(printf '%q' "$pubkey_text") >> ~/.ssh/authorized_keys" \
    || die "Failed to install SSH public key on remote host: $target"

  if [ "$remote_user" = "root" ]; then
    info "Remote target user is root. Public key was installed for root only."
  fi
}

sync_env_to_remote() {
  local target="$1"
  local port="$2"
  local tmpfile

  tmpfile=$(mktemp) || die "Failed to create temporary file."
  write_proxy_helper_script "$tmpfile"

  scp ${REMOTE_SCP_OPTS:-} -P "$port" "$tmpfile" "${target}:~/.devbox_env.sh" >/dev/null || die "Failed to copy env file to remote host: $target"
  remote_exec "$target" "$port" "grep -qxF 'source ~/.devbox_env.sh' ~/.bashrc || printf '\nsource ~/.devbox_env.sh\n' >> ~/.bashrc"
  rm -f "$tmpfile"
}

sync_files_to_remote() {
  local target="$1"
  local port="$2"
  local mapping src dst resolved_src expanded_dst remote_user remote_home

  remote_user=$(remote_user_name "$target")
  if [ "$remote_user" = "root" ]; then
    remote_home="/root"
  else
    remote_home="/home/${remote_user}"
  fi

  for mapping in "${DEPLOY_SYNC_FILES[@]-}"; do
    src=${mapping%%:*}
    dst=${mapping#*:}
    eval "resolved_src=$src"
    expanded_dst=$(expand_deploy_target_path "$dst" "$remote_user" "$remote_home")
    [ -n "$resolved_src" ] || continue
    [ -n "$expanded_dst" ] || continue
    [ -e "$resolved_src" ] || { warn "Skip missing path: $resolved_src"; continue; }
    info "Copying to remote: $resolved_src -> $expanded_dst"
    remote_copy "$resolved_src" "$target" "$port" "$expanded_dst"
  done
}

run_deploy_commands_on_remote() {
  local target="$1"
  local port="$2"
  local cmd

  for cmd in "${DEPLOY_COMMANDS[@]-}"; do
    [ -n "$cmd" ] || continue
    info "Running on remote host: $cmd"
    remote_exec "$target" "$port" "$cmd" || die "Remote deploy command failed on ${target}: $cmd"
  done
}

deploy_remote_host() {
  local target="$1"
  local port="${2:-22}"
  local pubkey_file
  local control_dir control_path use_mux="no"

  cleanup_remote_mux() {
    if [ "$use_mux" = "yes" ]; then
      stop_remote_connection_mux "$target" "$port" "$control_path"
      rm -rf "$control_dir"
      unset REMOTE_SSH_OPTS REMOTE_SCP_OPTS
    fi
  }

  ensure_local_ssh_key
  command_exists ssh || die "ssh command not found."
  command_exists scp || die "scp command not found."
  pubkey_file=$(find_default_pubkey) || die "No SSH public key found."
  trap cleanup_remote_mux EXIT

  if can_connect_remote_with_publickey "$target" "$port"; then
    info "Remote public key authentication is already available: $target"
  else
    info "Remote public key authentication is not available yet: $target"
    info "Trying password login so the public key can be installed."

    control_dir=$(mktemp -d) || die "Failed to create temporary directory for SSH control socket."
    control_path="${control_dir}/mux-%r@%h:%p"

    if start_remote_connection_mux "$target" "$port" "$control_path"; then
      use_mux="yes"
      REMOTE_SSH_OPTS="-o ControlPath=${control_path}"
      REMOTE_SCP_OPTS="-o ControlPath=${control_path}"
      info "Password login succeeded. Installing SSH public key."
      append_pubkey_to_remote "$target" "$port"
    else
      rm -rf "$control_dir"
      die "Unable to log in to ${target} on port ${port}. Check network reachability and credentials, or run: ssh-copy-id -i ${pubkey_file} -p ${port} ${target}"
    fi
  fi

  sync_env_to_remote "$target" "$port"
  sync_files_to_remote "$target" "$port"
  run_deploy_commands_on_remote "$target" "$port"

  info "Remote deploy completed: $target"
  trap - EXIT
  cleanup_remote_mux
}

