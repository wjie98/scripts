# Main Logic Section
# =========================

create_container() {
  local raw_name="${1:-}"
  local short_name full_name mount_dir image gpu_value ssh_port deploy_after_create
  local host_user host_group host_uid host_gid login_user
  local inherit_user_info create_user
  local run_args

  ensure_runtime_available

  if [ -n "$raw_name" ]; then
    short_name=$(strip_container_prefix "$raw_name")
  else
    short_name=$(prompt_input "Enter container name (without prefix)")
  fi

  [ -n "$short_name" ] || die "Container name is required."

  full_name=$(normalize_container_name "$short_name")

  if container_exists "$full_name"; then
    die "Container already exists: $full_name"
  fi

  if confirm "Inherit current host user information?" "yes"; then
    inherit_user_info="yes"
    create_user="yes"
    host_user=$(host_user_name)
    host_group=$(host_group_name)
    host_uid=$(host_user_uid)
    host_gid=$(host_user_gid)
  else
    inherit_user_info="no"
    host_user=$(prompt_input "Container login user (use 'root' to skip normal user setup)" "dev")
    [ -n "$host_user" ] || die "Container login user is required."

    if [ "$host_user" = "root" ]; then
      create_user="no"
      host_group="root"
      host_uid="0"
      host_gid="0"
    else
      create_user="yes"
      host_group=$(prompt_input "Container group name" "$host_user")
      [ -n "$host_group" ] || host_group="$host_user"
      host_uid=$(prompt_input "Container user UID (blank for default)" "1000")
      host_gid=$(prompt_input "Container user GID (blank for default)" "$host_uid")
    fi
  fi

  mount_dir=$(prompt_input "Project directory to mount" "$(pwd -P)")
  [ -d "$mount_dir" ] || die "Directory does not exist: $mount_dir"

  if is_home_dir "$mount_dir"; then
    die "Mounting the home directory is not allowed: $mount_dir"
  fi

  image=$(choose_image_interactively)
  gpu_value=$(collect_gpu_value || true)
  ssh_port=$(find_random_free_port)
  deploy_after_create=$(confirm "Deploy development environment after create?" "yes" && printf yes || printf no)
  login_user=$(resolve_login_user "$create_user" "$host_user")

  info "Creating container: $full_name"
  info "Image: $image"
  info "Mount: $mount_dir -> $CONTAINER_WORKDIR"
  info "SSH port mapping: ${ssh_port} -> 22"

  if [ "$create_user" = "yes" ]; then
    if [ "$inherit_user_info" = "yes" ]; then
      info "Container dev user: ${host_user} (${host_uid}:${host_gid}) from host"
    else
      info "Container dev user: ${host_user} (${host_uid}:${host_gid})"
    fi
  else
    info "Container login user: root"
  fi

  run_args=(
    -d
    --name "$full_name"
    --hostname "$full_name"
    -w "$CONTAINER_WORKDIR"
    -v "$mount_dir:$CONTAINER_WORKDIR"
    -p "${ssh_port}:22"
    -e "DEVBOX_CREATE_USER=$create_user"
    -e "DEVBOX_USER=$host_user"
    -e "DEVBOX_GROUP=$host_group"
    -e "DEVBOX_UID=$host_uid"
    -e "DEVBOX_GID=$host_gid"
    -e "DEVBOX_WORKDIR=$CONTAINER_WORKDIR"
  )

  if [ -n "$gpu_value" ]; then
    run_args+=(--gpus "$gpu_value")
  fi

  runtime run "${run_args[@]}" "$image" || die "Failed to create container: $full_name"

  info "Container created: $full_name"
  info "Connect via devbox SSH: bash ./devbox ssh ${short_name}"
  info "Direct SSH command: ssh ${login_user}@127.0.0.1 -p ${ssh_port}"

  if [ "$deploy_after_create" = "yes" ]; then
    deploy_local_container "$full_name"
  fi
}

start_container() {
  local container
  container=$(resolve_container_name "${1:-}")
  runtime start "$container" >/dev/null || die "Failed to start container: $container"
  info "Container started: $container"
}

stop_container() {
  local container
  container=$(resolve_container_name "${1:-}")
  runtime stop "$container" >/dev/null || die "Failed to stop container: $container"
  info "Container stopped: $container"
}

restart_container() {
  local container
  container=$(resolve_container_name "${1:-}")
  runtime restart "$container" >/dev/null || die "Failed to restart container: $container"
  info "Container restarted: $container"
}

delete_container() {
  local container
  container=$(resolve_container_name "${1:-}")

  container_exists "$container" || die "Container does not exist: $container"

  if container_is_running "$container"; then
    warn "Container is still running: $container"
    if confirm "Stop the running container before deleting it?" "yes"; then
      runtime stop "$container" >/dev/null || die "Failed to stop container: $container"
      info "Container stopped: $container"
    else
      die "Refusing to delete a running container."
    fi
  fi

  if ! confirm "Delete container '${container}'?" "no"; then
    die "Delete operation cancelled."
  fi

  runtime rm "$container" >/dev/null || die "Failed to delete container: $container"
  info "Container deleted: $container"
}

enter_container() {
  local container
  container=$(resolve_container_name "${1:-}")

  ensure_container_running "$container" "opening a shell"

  info "Opening maintenance shell: $container"
  info "Login user: root"

  if runtime exec "$container" sh -lc 'command -v bash >/dev/null 2>&1'; then
    runtime exec -it "$container" bash
  else
    runtime exec -it "$container" sh
  fi
}

ssh_container() {
  local container dev_user ssh_port private_key

  ensure_local_ssh_key
  command_exists ssh || die "ssh command not found."
  container=$(resolve_container_name "${1:-}")

  ensure_container_running "$container" "connecting over SSH"

  append_pubkey_to_container "$container"
  restart_sshd_in_container "$container"

  dev_user=$(get_container_dev_user "$container")
  ssh_port=$(get_container_ssh_port "$container" || true)
  private_key=$(find_default_private_key) || die "No matching SSH private key found for the default public key."
  [ -n "$ssh_port" ] || die "Container SSH port is not mapped: $container"

  info "Connecting via SSH: ${dev_user}@127.0.0.1:${ssh_port}"
  exec ssh -i "$private_key" -o IdentitiesOnly=yes -o PreferredAuthentications=publickey -p "$ssh_port" "${dev_user}@127.0.0.1"
}

list_containers() {
  local containers container

  ensure_runtime_available
  containers=$(list_prefixed_containers)

  if [ -z "$containers" ]; then
    info "No container found with prefix '${CONTAINER_PREFIX}'."
    return 0
  fi

  printf '%-28s %-10s %-8s %-12s %-28s %s\n' \
    'NAME' 'STATUS' 'SSH' 'DEV_USER' 'IMAGE' 'MOUNT'

  while IFS= read -r container; do
    [ -n "$container" ] || continue
    print_container_list_row "$container"
  done <<EOF
$containers
EOF
}

inspect_container() {
  local container status ssh_port dev_user dev_uid_gid image mount_source created_at workdir port_bindings

  container=$(resolve_container_name "${1:-}")
  container_exists "$container" || die "Container does not exist: $container"

  status=$(get_container_status "$container")
  ssh_port=$(get_container_ssh_port "$container" || true)
  dev_user=$(get_container_dev_user "$container")
  dev_uid_gid=$(get_container_dev_uid_gid "$container")
  image=$(get_container_image "$container")
  mount_source=$(get_container_mount_source "$container")
  created_at=$(get_container_created_at "$container")
  workdir=$(get_container_workdir "$container")
  port_bindings=$(get_container_port_bindings "$container")

  [ -n "$ssh_port" ] || ssh_port="-"
  [ -n "$dev_user" ] || dev_user="-"
  [ -n "$dev_uid_gid" ] || dev_uid_gid="-"
  [ -n "$image" ] || image="-"
  [ -n "$mount_source" ] || mount_source="-"
  [ -n "$created_at" ] || created_at="-"
  [ -n "$workdir" ] || workdir="-"
  [ -n "$port_bindings" ] || port_bindings="-"

  printf 'Name: %s\n' "$container"
  printf 'Short Name: %s\n' "$(strip_container_prefix "$container")"
  printf 'Status: %s\n' "$status"
  printf 'Image: %s\n' "$image"
  printf 'Dev User: %s\n' "$dev_user"
  printf 'Dev UID:GID: %s\n' "$dev_uid_gid"
  printf 'SSH Port: %s\n' "$ssh_port"
  printf 'Workdir: %s\n' "$workdir"
  printf 'Mount: %s -> %s\n' "$mount_source" "$CONTAINER_WORKDIR"
  printf 'Created At: %s\n' "$created_at"
  printf 'Port Bindings:\n%s\n' "$port_bindings"

  if [ "$status" != "running" ]; then
    printf 'Notes:\n'

    if [ "$ssh_port" = "-" ]; then
      printf -- '- SSH port is shown only when the container is running and the runtime reports an active mapping.\n'
    fi

    if [ "$port_bindings" = "-" ]; then
      printf -- '- Port binding details may be unavailable until the container is started.\n'
    fi

    printf -- '- This command does not start the container. Status is reported as-is.\n'
  fi
}

usage() {
  cat <<EOF
Usage:
  $0 list
  $0 run [name]
  $0 start [name]
  $0 stop [name]
  $0 restart [name]
  $0 rm [name]
  $0 info [name]
  $0 shell [name]
  $0 ssh [name]
  $0 deploy [name]
  $0 deploy-remote [user@]host [-p port]

Notes:
  - Container names can be passed without prefix. Prefix will be added automatically.
  - If no container name is passed to start/stop/restart/rm/info/shell/ssh/deploy, an interactive list will be shown.
  - Run requires an existing local image whose name starts with: ${IMAGE_PREFIX}
  - SSH port will be mapped automatically to a random free host port.
  - Shell opens a maintenance shell as root inside the container.
  - Ssh connects through the published container SSH port as the configured login user.
  - Deploy-remote works through SSH to the target user, tries password login only to install that user's public key, and does not touch root unless the target user is root.
  - DEPLOY_SYNC_FILES target paths support: {{DEVBOX_HOME}}, {{DEVBOX_USER}}, {{CONTAINER_WORKDIR}}
  - Runtime default: ${CONTAINER_CMD}
  - Prefix default: ${CONTAINER_PREFIX}

Environment overrides:
  CONTAINER_CMD
  CONTAINER_PREFIX
  IMAGE_PREFIX
  CONTAINER_WORKDIR
  PORT_RANGE_START
  PORT_RANGE_END
EOF
}

main() {
  local cmd="${1:-}"

  [ -n "$cmd" ] || {
    usage
    exit 1
  }

  shift || true

  case "$cmd" in
    list)
      list_containers
      ;;
    run)
      create_container "${1:-}"
      ;;
    start)
      start_container "${1:-}"
      ;;
    stop)
      stop_container "${1:-}"
      ;;
    restart)
      restart_container "${1:-}"
      ;;
    rm)
      delete_container "${1:-}"
      ;;
    info)
      inspect_container "${1:-}"
      ;;
    shell)
      enter_container "${1:-}"
      ;;
    ssh)
      ssh_container "${1:-}"
      ;;
    deploy)
      local container
      container=$(resolve_container_name "${1:-}")
      deploy_local_container "$container"
      ;;
    deploy-remote)
      [ -n "${1:-}" ] || die "Missing remote target. Usage: $0 deploy-remote [user@]host [-p port]"
      local target="$1"
      local port="22"
      shift || true

      while [ "$#" -gt 0 ]; do
        case "$1" in
          -p)
            shift
            [ -n "${1:-}" ] || die "Missing port after -p"
            port="$1"
            ;;
          *)
            die "Unknown deploy-remote argument: $1"
            ;;
        esac
        shift || true
      done

      deploy_remote_host "$target" "$port"
      ;;
    -h|--help|help)
      usage
      ;;
    *)
      die "Unknown command: $cmd"
      ;;
  esac
}

main "$@"
