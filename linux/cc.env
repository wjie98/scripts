# shellcheck shell=bash

# ==============================================================================
# Configuration
# ==============================================================================

# Shared environment variables applied to every Claude Code backend.
# Add one "KEY=value" entry per line.
CC_GLOBAL_ENV=(
    "CLAUDE_CODE_ENABLE_TELEMETRY=0"
    "CLAUDE_CODE_ATTRIBUTION_HEADER=0"
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1"
)

# Claude Code related environment variables that should be removed before a
# backend-specific environment is applied.
# Keep this list broad enough to avoid leaking settings from a previous backend.
CC_ENV_PREFIXES_TO_CLEAR=(
    "ANTHROPIC_"
    "CLAUDE_CODE_"
)

# Exact variable names to clear in addition to the prefixes above.
CC_ENV_NAMES_TO_CLEAR=(
    "CLAUDE_API_KEY"
    "CLAUDE_BASE_URL"
)

# Backend definitions.
# Format:
#   CC_BACKENDS+=("<name>|<aliases>|<description>")
#   CC_BACKEND_<name>=(
#       "KEY=value"
#       "KEY=value"
#   )
#
# Notes:
# - Put aliases in a space-separated string.
# - Use "{model}" in values that should follow ANTHROPIC_MODEL.
# - Adding a new Claude Code environment variable only requires adding another
#   "KEY=value" entry to the backend or CC_GLOBAL_ENV above.
CC_BACKENDS=(
    "deepseek|ds|DeepSeek - deepseek-v4"
    "moonshot|kimi|Moonshot AI - kimi-k2.6"
)

CC_BACKEND_deepseek=(
    "ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic"
    "ANTHROPIC_AUTH_TOKEN=<your DeepSeek API Key>"
    "ANTHROPIC_MODEL=deepseek-v4-pro[1m]"
    "ANTHROPIC_DEFAULT_OPUS_MODEL=deepseek-v4-pro[1m]"
    "ANTHROPIC_DEFAULT_SONNET_MODEL=deepseek-v4-pro[1m]"
    "ANTHROPIC_DEFAULT_HAIKU_MODEL=deepseek-v4-flash"
    "CLAUDE_CODE_SUBAGENT_MODEL=deepseek-v4-flash"
    "CLAUDE_CODE_EFFORT_LEVEL=max"
)

CC_BACKEND_moonshot=(
    "ANTHROPIC_BASE_URL=https://api.moonshot.cn/anthropic"
    "ANTHROPIC_AUTH_TOKEN=<your Moonshot API Key>"
    "ANTHROPIC_MODEL=kimi-k2.6"
    "ANTHROPIC_DEFAULT_OPUS_MODEL=kimi-k2.6"
    "ANTHROPIC_DEFAULT_SONNET_MODEL=kimi-k2.6"
    "ANTHROPIC_DEFAULT_HAIKU_MODEL=kimi-k2.6"
    "CLAUDE_CODE_SUBAGENT_MODEL=kimi-k2.6"
    "ENABLE_TOOL_SEARCH=false"
)

# ==============================================================================
# Utility functions
# ==============================================================================

_cc_backend_name() {
    local entry="${1}"
    printf '%s\n' "${entry%%|*}"
}

_cc_backend_aliases() {
    local entry="${1}"
    local rest="${entry#*|}"
    printf '%s\n' "${rest%%|*}"
}

_cc_backend_description() {
    local entry="${1}"
    printf '%s\n' "${entry#*|*|}"
}

_cc_backend_var_name() {
    local name="${1}"
    printf 'CC_BACKEND_%s\n' "${name//[^a-zA-Z0-9_]/_}"
}

_cc_find_backend() {
    local requested="${1}"
    local entry name aliases alias

    for entry in "${CC_BACKENDS[@]}"; do
        name="$(_cc_backend_name "${entry}")"
        aliases="$(_cc_backend_aliases "${entry}")"

        if [[ "${requested}" == "${name}" ]]; then
            printf '%s\n' "${name}"
            return 0
        fi

        for alias in ${aliases}; do
            if [[ "${requested}" == "${alias}" ]]; then
                printf '%s\n' "${name}"
                return 0
            fi
        done
    done

    return 1
}

_cc_print_help() {
    local entry name aliases description

    cat << EOF
Usage: cc <backend> [claude-options...]

Available backends (${#CC_BACKENDS[@]}):
EOF

    for entry in "${CC_BACKENDS[@]}"; do
        name="$(_cc_backend_name "${entry}")"
        aliases="$(_cc_backend_aliases "${entry}")"
        description="$(_cc_backend_description "${entry}")"

        if [[ -n "${aliases}" ]]; then
            printf '  %-12s %s (aliases: %s)\n' "${name}" "${description}" "${aliases}"
        else
            printf '  %-12s %s\n' "${name}" "${description}"
        fi
    done

    cat << 'EOF'

Examples:
  cc deepseek
  cc deepseek --version
  cc deepseek -p "hello"

Add or update backends in the Configuration section.
EOF
}

_cc_clear_claude_env() {
    local name prefix

    while IFS='=' read -r name _; do
        for prefix in "${CC_ENV_PREFIXES_TO_CLEAR[@]}"; do
            if [[ "${name}" == "${prefix}"* ]]; then
                unset "${name}"
                break
            fi
        done
    done < <(env)

    for name in "${CC_ENV_NAMES_TO_CLEAR[@]}"; do
        unset "${name}"
    done

    _cc_clear_configured_env
}

_cc_env_entry_key() {
    local entry="${1}"

    if [[ "${entry}" == *=* ]]; then
        printf '%s\n' "${entry%%=*}"
    fi
}

_cc_unset_env_entry() {
    local entry="${1}"
    local key

    key="$(_cc_env_entry_key "${entry}")"
    if [[ -n "${key}" ]]; then
        unset "${key}"
    fi
}

_cc_clear_configured_env() {
    local entry backend_entry backend_name backend_var

    for entry in "${CC_GLOBAL_ENV[@]}"; do
        _cc_unset_env_entry "${entry}"
    done

    for backend_entry in "${CC_BACKENDS[@]}"; do
        backend_name="$(_cc_backend_name "${backend_entry}")"
        backend_var="$(_cc_backend_var_name "${backend_name}")"

        if _cc_backend_config_exists "${backend_var}"; then
            local -n configured_env="${backend_var}"
            for entry in "${configured_env[@]}"; do
                _cc_unset_env_entry "${entry}"
            done
            unset -n configured_env
        fi
    done
}

_cc_export_env_entry() {
    local entry="${1}"
    local model="${2}"
    local key="${entry%%=*}"
    local value="${entry#*=}"

    value="${value//\{model\}/${model}}"
    export "${key}=${value}"
}

_cc_apply_env_list() {
    local model="${1}"
    local entry
    shift

    for entry in "$@"; do
        _cc_export_env_entry "${entry}" "${model}"
    done
}

_cc_backend_config_exists() {
    local backend_var="${1}"
    local declaration

    declaration="$(declare -p "${backend_var}" 2>/dev/null)" || return 1
    [[ "${declaration}" == declare\ -a* || "${declaration}" == declare\ -r\ -a* ]]
}


# ==============================================================================
# Business logic
# ==============================================================================

cc() {
    local backend="${1:-}"
    local backend_name backend_var

    if [[ -z "${backend}" || "${backend}" == "help" || "${backend}" == "--help" || "${backend}" == "-h" ]]; then
        _cc_print_help
        return 0
    fi

    backend_name="$(_cc_find_backend "${backend}")" || {
        echo "Error: Unknown backend '${backend}'" >&2
        echo "Run 'cc help' to see available backends." >&2
        return 1
    }

    backend_var="$(_cc_backend_var_name "${backend_name}")"

    if ! _cc_backend_config_exists "${backend_var}"; then
        echo "Error: Missing config array '${backend_var}' for backend '${backend_name}'." >&2
        return 1
    fi

    local -n backend_env="${backend_var}"

    shift

    (
        local entry model=""

        _cc_clear_claude_env

        for entry in "${backend_env[@]}"; do
            if [[ "${entry}" == ANTHROPIC_MODEL=* ]]; then
                model="${entry#*=}"
                break
            fi
        done

        _cc_apply_env_list "${model}" "${CC_GLOBAL_ENV[@]}"
        _cc_apply_env_list "${model}" "${backend_env[@]}"

        claude "$@"
    )
}
