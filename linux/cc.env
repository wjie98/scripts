cc() {
    local api="${1:-}"
    
    # 帮助信息：无参数或 help 时显示可用 API 列表
    if [[ -z "$api" || "$api" == "help" || "$api" == "--help" || "$api" == "-h" ]]; then
        cat << 'EOF'
Usage: cc <api-name> [claude-options...]

Available APIs (1):
  kimi    Moonshot AI - kimi-k2.5

Examples:
  cc kimi                    # 启动 claude 使用 kimi API
  cc kimi --version          # 查看 claude 版本
  cc kimi -p "hello"          # 直接执行 prompt

Add new APIs in the case statement below.
EOF
        return 0
    fi
    
    shift  # 移除 api 名称，剩余参数全部传给 claude
    
    case "$api" in
        kimi|moonshot)
            (
                export ANTHROPIC_BASE_URL="https://api.moonshot.cn/anthropic"
                export ANTHROPIC_AUTH_TOKEN="your-kimi-key-here"
                export ANTHROPIC_MODEL="kimi-k2.5"
                export ANTHROPIC_DEFAULT_OPUS_MODEL="${ANTHROPIC_MODEL}"
                export ANTHROPIC_DEFAULT_SONNET_MODEL="${ANTHROPIC_MODEL}"
                export ANTHROPIC_DEFAULT_HAIKU_MODEL="${ANTHROPIC_MODEL}"
                export CLAUDE_CODE_SUBAGENT_MODEL="${ANTHROPIC_MODEL}"
                claude "$@"
            )
            ;;
            
        # 添加新 API 模板（复制并修改）:
        # glm)
        #     (
        #         export ANTHROPIC_BASE_URL="https://open.bigmodel.cn/api/anthropic"
        #         export ANTHROPIC_AUTH_TOKEN="your-glm-key-here"
        #         export ANTHROPIC_MODEL="glm-4.6"
        #         export ANTHROPIC_DEFAULT_OPUS_MODEL="${ANTHROPIC_MODEL}"
        #         export ANTHROPIC_DEFAULT_SONNET_MODEL="${ANTHROPIC_MODEL}"
        #         export ANTHROPIC_DEFAULT_HAIKU_MODEL="${ANTHROPIC_MODEL}"
        #         export CLAUDE_CODE_SUBAGENT_MODEL="${ANTHROPIC_MODEL}"
        #         # 可以在这里添加其他特定的环境变量微调
        #         claude "$@"
        #     )
        #     ;;
            
        *)
            echo "Error: Unknown API '$api'" >&2
            echo "Run 'cc help' to see available APIs" >&2
            return 1
            ;;
    esac
}
