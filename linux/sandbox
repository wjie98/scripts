#!/usr/bin/env bash
set -Eeuo pipefail

################################################################################
# Config
################################################################################

# Host home directory used by config items below.
HOST_HOME="${HOME:-/nonexistent}"

# Default interactive shell when no CLI command is provided.
DEFAULT_SHELL="bash"

# Feature toggles.
ENABLE_GPU=1
ENABLE_X11=1
ENABLE_WAYLAND=1
ENABLE_NET=1

# If enabled, missing configured mount sources become fatal errors.
STRICT_MOUNTS=1

# If enabled, the current working directory is automatically added as RW mount.
AUTO_MOUNT_CWD=1

# Output controls.
PRINT_CONFIG_SUMMARY=1
DEBUG_PRINT_FINAL_CMD=0

# If enabled, disable bash history inside sandbox.
DISABLE_HISTORY=1

# Exact directories forbidden as startup CWD.
FORBIDDEN_CWD_EXACT=(
  "/"
  "/home"
)

# Directory prefixes forbidden as startup CWD.
FORBIDDEN_CWD_PREFIXES=(
  "/etc"
  "/usr"
  "/bin"
  "/sbin"
  "/lib"
  "/lib64"
  "/var"
  "/run"
  "/boot"
  "/root"
)

# Allowed prefixes for RW mounts.
# If empty, no RW prefix restriction is applied.
ALLOWED_RW_PREFIXES=(
  # "${HOST_HOME}/projects"
  # "${HOST_HOME}/work"
  # "${HOST_HOME}/.cache"
  # "/data"
)

# Additional read-only mounts.
RO_MOUNTS=(
)

# Additional read-write mounts.
RW_MOUNTS=(
  "${HOST_HOME}/.cache"
  "${HOST_HOME}/.pi"
  "${HOST_HOME}/.omp"
)

# Additional device binds.
EXTRA_DEVICE_BINDS=(
)

# Additional runtime path binds.
EXTRA_RUNTIME_BINDS=(
)

# Commands executed inside sandbox before launching the final command.
PRE_COMMANDS=(
)

# Environment variables to unset inside sandbox.
UNSET_ENVS=(
  "LD_LIBRARY_PATH"
  "PYTHONPATH"
  "CONDA_PREFIX"
  "CONDA_DEFAULT_ENV"
  "VIRTUAL_ENV"
  "BASH_ENV"
  "ENV"
)

# Extra environment variables injected into sandbox.
# Format: NAME=VALUE
EXTRA_ENVS=(
)

################################################################################
# Helper functions
################################################################################

SCRIPT_NAME="$(basename "${BASH_SOURCE[0]}")"

log()  { printf '[%s] %s\n' "${SCRIPT_NAME}" "$*" >&2; }
warn() { printf '[%s] WARN: %s\n' "${SCRIPT_NAME}" "$*" >&2; }
die()  { printf '[%s] ERROR: %s\n' "${SCRIPT_NAME}" "$*" >&2; exit 1; }

on_error() {
  local code=$?
  printf '[%s] ERROR: command failed at line %s: %s (exit=%s)\n' \
    "${SCRIPT_NAME}" "${1:-unknown}" "${2:-unknown}" "${code}" >&2
  exit "${code}"
}
trap 'on_error "${LINENO}" "${BASH_COMMAND}"' ERR

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "required command not found: $1"
}

path_exists_any() {
  local path="$1"
  [[ -e "${path}" || -L "${path}" || -S "${path}" ]]
}

is_abs() {
  [[ "$1" == /* ]]
}

real_path() {
  local path="$1"

  if command -v readlink >/dev/null 2>&1; then
    readlink -f -- "${path}" 2>/dev/null && return 0
  fi

  if command -v realpath >/dev/null 2>&1; then
    realpath -- "${path}" 2>/dev/null && return 0
  fi

  die "cannot resolve real path: ${path}"
}

normalize_existing_path() {
  local path="$1"
  if path_exists_any "${path}"; then
    real_path "${path}"
  else
    printf '%s\n' "${path}"
  fi
}

normalize_array_paths() {
  local -n ref="$1"
  local item out=()

  for item in "${ref[@]}"; do
    [[ -n "${item}" ]] || continue
    out+=("$(normalize_existing_path "${item}")")
  done

  ref=("${out[@]}")
}

dedup_array() {
  local -n ref="$1"
  local -A seen=()
  local item out=()

  for item in "${ref[@]}"; do
    [[ -n "${item}" ]] || continue
    if [[ -z "${seen["${item}"]+x}" ]]; then
      seen["${item}"]=1
      out+=("${item}")
    fi
  done

  ref=("${out[@]}")
}

validate_toggle() {
  case "$2" in
    0|1) ;;
    *) die "$1 must be 0 or 1, got: $2" ;;
  esac
}

validate_abs_list() {
  local name="$1"
  local -n ref="$1"
  local item

  for item in "${ref[@]}"; do
    [[ -n "${item}" ]] || die "${name} contains an empty item"
    is_abs "${item}" || die "${name} contains a non-absolute path: ${item}"
  done
}

validate_env_lists() {
  local item

  for item in "${UNSET_ENVS[@]}"; do
    [[ -n "${item}" ]] || die "UNSET_ENVS contains an empty item"
    [[ "${item}" != *=* ]] || die "UNSET_ENVS should contain names only: ${item}"
  done

  for item in "${EXTRA_ENVS[@]}"; do
    [[ -n "${item}" ]] || die "EXTRA_ENVS contains an empty item"
    [[ "${item}" == *=* ]] || die "EXTRA_ENVS item must be NAME=VALUE: ${item}"
  done
}

validate_pre_commands() {
  local item
  for item in "${PRE_COMMANDS[@]}"; do
    [[ -n "${item}" ]] || die "PRE_COMMANDS contains an empty item"
  done
}

pwd_real() {
  pwd -P || die "failed to resolve current working directory"
}

get_user_homes() {
  if command -v getent >/dev/null 2>&1 && getent passwd >/dev/null 2>&1; then
    getent passwd | awk -F: '{print $6}'
    return 0
  fi

  if [[ -r /etc/passwd ]]; then
    awk -F: '{print $6}' /etc/passwd
    return 0
  fi

  [[ -n "${HOME:-}" ]] && printf '%s\n' "${HOME}" || true
}

is_exact_user_home() {
  local target="$1"
  local home home_real

  while IFS= read -r home; do
    [[ -n "${home}" ]] || continue
    path_exists_any "${home}" || continue
    home_real="$(real_path "${home}")" || continue
    [[ "${target}" == "${home_real}" ]] && return 0
  done < <(get_user_homes || true)

  return 1
}

path_is_same_or_child() {
  local path="$1"
  local prefix="$2"

  [[ "${prefix}" == "/" ]] && return 0
  [[ "${path}" == "${prefix}" || "${path}" == "${prefix}/"* ]]
}

path_matches_any_prefix() {
  local path="$1"
  shift
  local prefix

  for prefix in "$@"; do
    [[ -n "${prefix}" ]] || continue
    if path_is_same_or_child "${path}" "${prefix}"; then
      return 0
    fi
  done

  return 1
}

validate_cwd_rules() {
  local cwd="$1"
  local path

  for path in "${FORBIDDEN_CWD_EXACT[@]}"; do
    [[ -n "${path}" ]] || continue
    [[ "${cwd}" != "${path}" ]] || die "current directory is forbidden: ${cwd}"
  done

  if [[ "${#FORBIDDEN_CWD_PREFIXES[@]}" -gt 0 ]] &&
     path_matches_any_prefix "${cwd}" "${FORBIDDEN_CWD_PREFIXES[@]}"; then
    die "current directory is under a forbidden prefix: ${cwd}"
  fi

  if is_exact_user_home "${cwd}"; then
    die "current directory is exactly a user's home directory: ${cwd}"
  fi

  if [[ "${AUTO_MOUNT_CWD}" -eq 1 && "${#ALLOWED_RW_PREFIXES[@]}" -gt 0 ]] &&
     ! path_matches_any_prefix "${cwd}" "${ALLOWED_RW_PREFIXES[@]}"; then
    die "current directory is outside ALLOWED_RW_PREFIXES and AUTO_MOUNT_CWD=1: ${cwd}"
  fi
}

validate_rw_mount_rules() {
  local path

  [[ "${#ALLOWED_RW_PREFIXES[@]}" -eq 0 ]] && return 0

  for path in "${RW_MOUNTS[@]}"; do
    if ! path_matches_any_prefix "${path}" "${ALLOWED_RW_PREFIXES[@]}"; then
      die "RW_MOUNTS path is outside ALLOWED_RW_PREFIXES: ${path}"
    fi
  done
}

print_args() {
  local arg
  printf '[%s] Final bwrap command:\n' "${SCRIPT_NAME}" >&2
  for arg in "$@"; do
    printf ' %q' "${arg}" >&2
  done
  printf '\n' >&2
}

mount_status() {
  if path_exists_any "$1"; then
    printf 'effective'
  elif [[ "${STRICT_MOUNTS}" -eq 1 ]]; then
    printf 'invalid'
  else
    printf 'inactive'
  fi
}

print_status_list() {
  local title="$1"
  shift
  local item

  printf '[%s] %s\n' "${SCRIPT_NAME}" "${title}" >&2
  if [[ "$#" -eq 0 ]]; then
    printf '[%s]   - (none)\n' "${SCRIPT_NAME}" >&2
    return 0
  fi

  for item in "$@"; do
    printf '[%s]   - %s: %s\n' "${SCRIPT_NAME}" "$(mount_status "${item}")" "${item}" >&2
  done
}

print_plain_list() {
  local title="$1"
  shift
  local item

  printf '[%s] %s\n' "${SCRIPT_NAME}" "${title}" >&2
  if [[ "$#" -eq 0 ]]; then
    printf '[%s]   - (empty, no restriction)\n' "${SCRIPT_NAME}" >&2
    return 0
  fi

  for item in "$@"; do
    printf '[%s]   - %s\n' "${SCRIPT_NAME}" "${item}" >&2
  done
}

warn_mount_conflicts() {
  local ro rw
  for ro in "${RO_MOUNTS[@]}"; do
    for rw in "${RW_MOUNTS[@]}"; do
      [[ "${ro}" == "${rw}" ]] && warn "same path appears in both RO_MOUNTS and RW_MOUNTS, RW overrides RO: ${ro}"
    done
  done
}

build_prompt_prefix() {
  local level="$1"
  local prefix=""
  local i
  for ((i=0; i<level; i++)); do
    prefix+="(sandbox)"
  done
  printf '%s\n' "${prefix}"
}

print_summary() {
  local x11="inactive"
  local wayland="inactive"
  local ssh="inactive"
  local gpu="inactive"
  local item

  if [[ "${ENABLE_X11}" -eq 1 && -n "${DISPLAY:-}" && -d /tmp/.X11-unix ]]; then
    x11="effective"
  fi
  if [[ "${ENABLE_WAYLAND}" -eq 1 && -n "${XDG_RUNTIME_DIR:-}" && -n "${WAYLAND_DISPLAY:-}" &&
        -S "${XDG_RUNTIME_DIR}/${WAYLAND_DISPLAY}" ]]; then
    wayland="effective"
  fi
  if [[ -n "${SSH_AUTH_SOCK:-}" && -S "${SSH_AUTH_SOCK}" ]]; then
    ssh="effective"
  fi
  if [[ "${ENABLE_GPU}" -eq 1 && ( -d /dev/dri || -e /dev/kfd || -e /dev/nvidiactl || -e /dev/dxg ) ]]; then
    gpu="effective"
  fi

  printf '[%s] Configuration summary\n' "${SCRIPT_NAME}" >&2
  printf '[%s]   - CWD=%s\n' "${SCRIPT_NAME}" "${CWD_REAL}" >&2
  printf '[%s]   - ENABLE_GPU=%s\n' "${SCRIPT_NAME}" "${ENABLE_GPU}" >&2
  printf '[%s]   - ENABLE_X11=%s\n' "${SCRIPT_NAME}" "${ENABLE_X11}" >&2
  printf '[%s]   - ENABLE_WAYLAND=%s\n' "${SCRIPT_NAME}" "${ENABLE_WAYLAND}" >&2
  printf '[%s]   - ENABLE_NET=%s\n' "${SCRIPT_NAME}" "${ENABLE_NET}" >&2
  printf '[%s]   - AUTO_MOUNT_CWD=%s\n' "${SCRIPT_NAME}" "${AUTO_MOUNT_CWD}" >&2
  printf '[%s]   - STRICT_MOUNTS=%s\n' "${SCRIPT_NAME}" "${STRICT_MOUNTS}" >&2

  printf '[%s] Runtime features:\n' "${SCRIPT_NAME}" >&2
  printf '[%s]   - X11=%s\n' "${SCRIPT_NAME}" "${x11}" >&2
  printf '[%s]   - Wayland=%s\n' "${SCRIPT_NAME}" "${wayland}" >&2
  printf '[%s]   - SSH agent=%s\n' "${SCRIPT_NAME}" "${ssh}" >&2
  printf '[%s]   - GPU=%s\n' "${SCRIPT_NAME}" "${gpu}" >&2

  print_plain_list  "Forbidden CWD exact paths:"   "${FORBIDDEN_CWD_EXACT[@]}"
  print_plain_list  "Forbidden CWD prefixes:"      "${FORBIDDEN_CWD_PREFIXES[@]}"
  print_plain_list  "Allowed RW prefixes:"         "${ALLOWED_RW_PREFIXES[@]}"
  print_status_list "Read-only mounts:"            "${RO_MOUNTS[@]}"
  print_status_list "Read-write mounts:"           "${RW_MOUNTS[@]}"
  print_status_list "Extra device binds:"          "${EXTRA_DEVICE_BINDS[@]}"
  print_status_list "Extra runtime binds:"         "${EXTRA_RUNTIME_BINDS[@]}"

  printf '[%s] PRE_COMMANDS:\n' "${SCRIPT_NAME}" >&2
  if [[ "${#PRE_COMMANDS[@]}" -eq 0 ]]; then
    printf '[%s]   - (none)\n' "${SCRIPT_NAME}" >&2
  else
    for item in "${PRE_COMMANDS[@]}"; do
      printf '[%s]   - %s\n' "${SCRIPT_NAME}" "${item}" >&2
    done
  fi

  printf '[%s] Final command:\n' "${SCRIPT_NAME}" >&2
  if [[ "${#FINAL_CMD[@]}" -eq 0 ]]; then
    printf '[%s]   - %s\n' "${SCRIPT_NAME}" "${DEFAULT_SHELL}" >&2
  else
    for item in "${FINAL_CMD[@]}"; do
      printf '[%s]   - %s\n' "${SCRIPT_NAME}" "${item}" >&2
    done
  fi
}

declare -a BWRAP_ARGS=()
declare -A ENSURED_DIRS=()

ensure_dir_once() {
  local dir="$1"
  [[ -n "${dir}" && "${dir}" != "/" ]] || return 0

  if [[ -z "${ENSURED_DIRS["${dir}"]+x}" ]]; then
    BWRAP_ARGS+=("--dir" "${dir}")
    ENSURED_DIRS["${dir}"]=1
  fi
}

ensure_shadow_parent_dirs() {
  local dst="$1"
  local dir stack=() i

  case "${dst}" in
    /tmp/*|/dev/shm/*)
      dir="$(dirname "${dst}")"
      while [[ "${dir}" != "/" && "${dir}" != "." ]]; do
        stack+=("${dir}")
        dir="$(dirname "${dir}")"
      done
      for ((i=${#stack[@]}-1; i>=0; i--)); do
        ensure_dir_once "${stack[i]}"
      done
      ;;
  esac
}

add_bind() {
  local mode="$1"
  local src="$2"
  local dst="${3:-$2}"

  if ! path_exists_any "${src}"; then
    if [[ "${STRICT_MOUNTS}" -eq 1 ]]; then
      die "${mode} mount source does not exist: ${src}"
    else
      warn "${mode} mount skipped because source does not exist: ${src}"
      return 0
    fi
  fi

  ensure_shadow_parent_dirs "${dst}"

  case "${mode}" in
    ro)  BWRAP_ARGS+=("--ro-bind"  "${src}" "${dst}") ;;
    rw)  BWRAP_ARGS+=("--bind"     "${src}" "${dst}") ;;
    dev) BWRAP_ARGS+=("--dev-bind" "${src}" "${dst}") ;;
    *) die "unknown bind mode: ${mode}" ;;
  esac
}

build_shell_payload() {
  local payload=""
  local cmd

  payload+=$'set -Eeuo pipefail\n'
  payload+=$'cd "$PWD"\n'

  for cmd in "${PRE_COMMANDS[@]}"; do
    payload+="${cmd}"$'\n'
  done

  payload+=$'if [[ "$#" -eq 0 ]]; then\n'
  payload+="  cat > /tmp/.sandbox_bashrc <<'EOF_SANDBOX_RC'"$'\n'
  payload+=$'[[ -r /etc/bash.bashrc ]] && source /etc/bash.bashrc || true\n'
  payload+=$'[[ -r ~/.bashrc ]] && source ~/.bashrc || true\n'
  payload+=$'_sandbox_apply_prompt() {\n'
  payload+=$'  local prefix="${SANDBOX_PROMPT_PREFIX:-"(sandbox)"}"\n'
  payload+=$'  case "${PS1:-}" in\n'
  payload+=$'    "${prefix} "*) ;;\n'
  payload+=$'    *) PS1="${prefix} ${PS1:-\\u@\\h:\\w\\\\$ }" ;;\n'
  payload+=$'  esac\n'
  payload+=$'}\n'
  payload+=$'_sandbox_apply_prompt\n'
  payload+=$'if [[ -n "${PROMPT_COMMAND:-}" ]]; then\n'
  payload+=$'  PROMPT_COMMAND="_sandbox_apply_prompt; ${PROMPT_COMMAND}"\n'
  payload+=$'else\n'
  payload+=$'  PROMPT_COMMAND="_sandbox_apply_prompt"\n'
  payload+=$'fi\n'
  payload+="EOF_SANDBOX_RC"$'\n'
  payload+=$'  exec bash --rcfile /tmp/.sandbox_bashrc -i\n'
  payload+=$'else\n'
  payload+=$'  exec "$@"\n'
  payload+=$'fi\n'

  printf '%s' "${payload}"
}

################################################################################
# Main flow
################################################################################

require_cmd bwrap
require_cmd bash
require_cmd awk

validate_toggle "ENABLE_GPU"            "${ENABLE_GPU}"
validate_toggle "ENABLE_X11"            "${ENABLE_X11}"
validate_toggle "ENABLE_WAYLAND"        "${ENABLE_WAYLAND}"
validate_toggle "ENABLE_NET"            "${ENABLE_NET}"
validate_toggle "STRICT_MOUNTS"         "${STRICT_MOUNTS}"
validate_toggle "AUTO_MOUNT_CWD"        "${AUTO_MOUNT_CWD}"
validate_toggle "PRINT_CONFIG_SUMMARY"  "${PRINT_CONFIG_SUMMARY}"
validate_toggle "DEBUG_PRINT_FINAL_CMD" "${DEBUG_PRINT_FINAL_CMD}"
validate_toggle "DISABLE_HISTORY"       "${DISABLE_HISTORY}"

validate_abs_list "RO_MOUNTS"
validate_abs_list "RW_MOUNTS"
validate_abs_list "EXTRA_DEVICE_BINDS"
validate_abs_list "EXTRA_RUNTIME_BINDS"
validate_abs_list "FORBIDDEN_CWD_EXACT"
validate_abs_list "FORBIDDEN_CWD_PREFIXES"
validate_abs_list "ALLOWED_RW_PREFIXES"
validate_env_lists
validate_pre_commands

normalize_array_paths "RO_MOUNTS"
normalize_array_paths "RW_MOUNTS"
normalize_array_paths "EXTRA_DEVICE_BINDS"
normalize_array_paths "EXTRA_RUNTIME_BINDS"
normalize_array_paths "FORBIDDEN_CWD_EXACT"
normalize_array_paths "FORBIDDEN_CWD_PREFIXES"
normalize_array_paths "ALLOWED_RW_PREFIXES"

dedup_array "RO_MOUNTS"
dedup_array "RW_MOUNTS"
dedup_array "EXTRA_DEVICE_BINDS"
dedup_array "EXTRA_RUNTIME_BINDS"
dedup_array "FORBIDDEN_CWD_EXACT"
dedup_array "FORBIDDEN_CWD_PREFIXES"
dedup_array "ALLOWED_RW_PREFIXES"

CWD_REAL="$(pwd_real)"
validate_cwd_rules "${CWD_REAL}"

if [[ "${AUTO_MOUNT_CWD}" -eq 1 ]]; then
  RW_MOUNTS+=("${CWD_REAL}")
fi

normalize_array_paths "RW_MOUNTS"
dedup_array "RW_MOUNTS"
validate_rw_mount_rules
warn_mount_conflicts

declare -a FINAL_CMD=()
if [[ "$#" -gt 0 ]]; then
  FINAL_CMD=("$@")
fi

if [[ "${PRINT_CONFIG_SUMMARY}" -eq 1 ]]; then
  print_summary "$@"
fi

HOST_SANDBOX_LEVEL_RAW="${SANDBOX_LEVEL:-0}"
if [[ "${HOST_SANDBOX_LEVEL_RAW}" =~ ^[0-9]+$ ]]; then
  NEXT_SANDBOX_LEVEL=$((HOST_SANDBOX_LEVEL_RAW + 1))
else
  NEXT_SANDBOX_LEVEL=1
fi

SANDBOX_PROMPT_PREFIX="$(build_prompt_prefix "${NEXT_SANDBOX_LEVEL}")"
SANDBOX_RUNTIME_DIR="/tmp/.sandbox-runtime"
SANDBOX_WAYLAND_SOCK="${SANDBOX_RUNTIME_DIR}/wayland.sock"
SANDBOX_SSH_AUTH_SOCK="${SANDBOX_RUNTIME_DIR}/ssh-agent.sock"
SANDBOX_XAUTHORITY="${SANDBOX_RUNTIME_DIR}/Xauthority"

BWRAP_ARGS+=(
  "--die-with-parent"
  "--unshare-all"
)

if [[ "${ENABLE_NET}" -eq 1 ]]; then
  BWRAP_ARGS+=("--share-net")
fi

BWRAP_ARGS+=(
  "--ro-bind" "/" "/"
  "--proc" "/proc"
  "--dev" "/dev"
  "--tmpfs" "/tmp"
  "--tmpfs" "/dev/shm"
  "--chdir" "${CWD_REAL}"
)

ensure_dir_once "${SANDBOX_RUNTIME_DIR}"

BWRAP_ARGS+=(
  "--setenv" "PWD" "${CWD_REAL}"
  "--setenv" "SANDBOX_ACTIVE" "1"
  "--setenv" "SANDBOX_LEVEL" "${NEXT_SANDBOX_LEVEL}"
  "--setenv" "SANDBOX_PROMPT_PREFIX" "${SANDBOX_PROMPT_PREFIX}"
)

if [[ "${DISABLE_HISTORY}" -eq 1 ]]; then
  BWRAP_ARGS+=(
    "--setenv" "HISTFILE" "/dev/null"
    "--setenv" "HISTSIZE" "0"
    "--setenv" "HISTFILESIZE" "0"
  )
fi

for env_name in "${UNSET_ENVS[@]}"; do
  BWRAP_ARGS+=("--unsetenv" "${env_name}")
done

for kv in "${EXTRA_ENVS[@]}"; do
  BWRAP_ARGS+=("--setenv" "${kv%%=*}" "${kv#*=}")
done

for path in "${RO_MOUNTS[@]}"; do
  add_bind ro "${path}" "${path}"
done

for path in "${RW_MOUNTS[@]}"; do
  add_bind rw "${path}" "${path}"
done

for path in "${EXTRA_DEVICE_BINDS[@]}"; do
  add_bind dev "${path}" "${path}"
done

for path in "${EXTRA_RUNTIME_BINDS[@]}"; do
  add_bind rw "${path}" "${path}"
done

if [[ "${ENABLE_X11}" -eq 1 && -n "${DISPLAY:-}" ]]; then
  BWRAP_ARGS+=("--setenv" "DISPLAY" "${DISPLAY}")

  if [[ -d /tmp/.X11-unix ]]; then
    add_bind ro "/tmp/.X11-unix" "/tmp/.X11-unix"
  else
    warn "X11 enabled but /tmp/.X11-unix does not exist"
  fi

  if [[ -n "${XAUTHORITY:-}" ]]; then
    if [[ -f "${XAUTHORITY}" ]]; then
      add_bind ro "${XAUTHORITY}" "${SANDBOX_XAUTHORITY}"
      BWRAP_ARGS+=("--setenv" "XAUTHORITY" "${SANDBOX_XAUTHORITY}")
    else
      warn "XAUTHORITY is set but file does not exist: ${XAUTHORITY}"
    fi
  fi
fi

if [[ "${ENABLE_WAYLAND}" -eq 1 && -n "${XDG_RUNTIME_DIR:-}" && -n "${WAYLAND_DISPLAY:-}" ]]; then
  if [[ -S "${XDG_RUNTIME_DIR}/${WAYLAND_DISPLAY}" ]]; then
    add_bind rw "${XDG_RUNTIME_DIR}/${WAYLAND_DISPLAY}" "${SANDBOX_WAYLAND_SOCK}"
    BWRAP_ARGS+=(
      "--setenv" "XDG_RUNTIME_DIR" "${SANDBOX_RUNTIME_DIR}"
      "--setenv" "WAYLAND_DISPLAY" "$(basename "${SANDBOX_WAYLAND_SOCK}")"
    )
  else
    warn "Wayland enabled but socket does not exist: ${XDG_RUNTIME_DIR}/${WAYLAND_DISPLAY}"
  fi
fi

if [[ -n "${SSH_AUTH_SOCK:-}" ]]; then
  if [[ -S "${SSH_AUTH_SOCK}" ]]; then
    add_bind rw "${SSH_AUTH_SOCK}" "${SANDBOX_SSH_AUTH_SOCK}"
    BWRAP_ARGS+=("--setenv" "SSH_AUTH_SOCK" "${SANDBOX_SSH_AUTH_SOCK}")
  else
    warn "SSH_AUTH_SOCK is set but not a socket: ${SSH_AUTH_SOCK}"
  fi
fi

if [[ "${ENABLE_GPU}" -eq 1 ]]; then
  [[ -d /dev/dri ]] && BWRAP_ARGS+=("--dev-bind" "/dev/dri" "/dev/dri")
  [[ -e /dev/kfd ]] && BWRAP_ARGS+=("--dev-bind" "/dev/kfd" "/dev/kfd")
  [[ -e /dev/dxg ]] && BWRAP_ARGS+=("--dev-bind" "/dev/dxg" "/dev/dxg")

  for dev in \
    /dev/nvidiactl \
    /dev/nvidia-modeset \
    /dev/nvidia-uvm \
    /dev/nvidia-uvm-tools \
    /dev/nvidia0 \
    /dev/nvidia1 \
    /dev/nvidia2 \
    /dev/nvidia3 \
    /dev/nvidia4 \
    /dev/nvidia5 \
    /dev/nvidia6 \
    /dev/nvidia7
  do
    [[ -e "${dev}" ]] && BWRAP_ARGS+=("--dev-bind" "${dev}" "${dev}")
  done

  for env_name in \
    CUDA_VISIBLE_DEVICES \
    NVIDIA_VISIBLE_DEVICES \
    NVIDIA_DRIVER_CAPABILITIES \
    ROCM_PATH \
    HIP_VISIBLE_DEVICES \
    GPU_DEVICE_ORDINAL
  do
    [[ -n "${!env_name:-}" ]] && BWRAP_ARGS+=("--setenv" "${env_name}" "${!env_name}")
  done
fi

SHELL_PAYLOAD="$(build_shell_payload)"

declare -a EXEC_CMD=()
if [[ "${#FINAL_CMD[@]}" -gt 0 ]]; then
  EXEC_CMD=("bash" "-lc" "${SHELL_PAYLOAD}" "bash" "${FINAL_CMD[@]}")
else
  EXEC_CMD=("bash" "-lc" "${SHELL_PAYLOAD}" "bash")
fi

if [[ "${DEBUG_PRINT_FINAL_CMD}" -eq 1 ]]; then
  print_args bwrap "${BWRAP_ARGS[@]}" -- "${EXEC_CMD[@]}"
fi

exec bwrap "${BWRAP_ARGS[@]}" -- "${EXEC_CMD[@]}"

