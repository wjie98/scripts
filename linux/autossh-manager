#!/usr/bin/env bash

# ==============================================================================
# Configuration
# ==============================================================================

SCRIPT_NAME="$(basename "$0")"
SCRIPT_VERSION="4.0"

# Shared autossh and ssh options applied to every tunnel unless overridden.
# Keep each option as one array item so spaces in later arguments are safe.
GLOBAL_AUTOSSH_OPTIONS=(
    "-M"
    "0"
    "-f"
)

GLOBAL_SSH_OPTIONS=(
    "-T"
    "-q"
    "-n"
    "-N"
)

# Optional shared SSH settings. Per-tunnel values override these defaults.
GLOBAL_SSH_JUMP=""
GLOBAL_SSH_KEY=""

# Tunnel definitions.
#
# Each tunnel is a readable key/value block. Supported keys:
#   group        Required. Group name used by start/stop/status commands.
#   name         Required. Tunnel name displayed in status output.
#   mode         Optional. local-forward, remote-forward, or socks-proxy.
#                Short aliases local/L, remote/R, and dynamic/D are accepted.
#                Default: local-forward.
#   local        Required. Local bind address/port, for example :22022.
#   remote       Required for local-forward and remote-forward mode.
#                Remote host:port.
#   server       Required. SSH login server, optionally server:port.
#   ssh_port     Optional. SSH port. Overrides server:port when both are set.
#   jump         Optional. SSH jump host, equivalent to ssh -J.
#   key          Optional. SSH identity file, equivalent to ssh -i.
#   ssh_options  Optional. Extra ssh options split on spaces.
#   description  Optional. Human-readable note shown in --help.
#
# Add a new tunnel by copying one block and changing its values.
TUNNEL_DEFINITIONS=(
"
group=starry
name=gpu02
mode=local-forward
local=:22022
remote=127.0.0.1:22022
server=gpu02
description=GPU02 SSH tunnel
"

# Example with a per-tunnel identity file:
# "
# group=test
# name=test-key
# mode=local-forward
# local=:2222
# remote=127.0.0.1:22
# server=test-server
# key=~/.ssh/id_rsa
# description=Example tunnel with a custom SSH key
# "
)

is_tunnel_running() {
    local id="${1}"
    local pattern

# ==============================================================================
# Utility Functions
# ==============================================================================

if [[ -z "${BASH_VERSION:-}" ]]; then
    echo "Error: ${SCRIPT_NAME} must be run with bash, not ${SHELL:-the current shell}." >&2
    echo "Run it directly as ${0} or with: bash ${0}" >&2
    exit 1
fi

declare -a TUNNEL_IDS=()
declare -a TUNNEL_GROUP=()
declare -a TUNNEL_NAME=()
declare -a TUNNEL_MODE=()
declare -a TUNNEL_LOCAL=()
declare -a TUNNEL_REMOTE=()
declare -a TUNNEL_SERVER=()
declare -a TUNNEL_SSH_PORT=()
declare -a TUNNEL_JUMP=()
declare -a TUNNEL_KEY=()
declare -a TUNNEL_SSH_OPTIONS=()
declare -a TUNNEL_DESCRIPTION=()
declare -a BUILT_AUTOSSH_COMMAND=()

trim() {
    local value="${1}"

    value="${value#"${value%%[![:space:]]*}"}"
    value="${value%"${value##*[![:space:]]}"}"
    printf '%s\n' "${value}"
}

expand_path() {
    local value="${1}"

    if [[ "${value}" == "~" ]]; then
        printf '%s\n' "${HOME}"
    elif [[ "${value}" == "~/"* ]]; then
        printf '%s\n' "${HOME}/${value#~/}"
    else
        printf '%s\n' "${value}"
    fi
}

normalize_mode() {
    local mode="${1:-local-forward}"

    case "${mode}" in
        local-forward|local|L)
            printf '%s\n' "local-forward"
            ;;
        remote-forward|remote|R)
            printf '%s\n' "remote-forward"
            ;;
        socks-proxy|dynamic|D)
            printf '%s\n' "socks-proxy"
            ;;
        *)
            return 1
            ;;
    esac
}

mode_label() {
    local mode="${1}"

    case "${mode}" in
        local-forward)
            printf '%s\n' "local-forward"
            ;;
        remote-forward)
            printf '%s\n' "remote-forward"
            ;;
        socks-proxy)
            printf '%s\n' "socks-proxy"
            ;;
    esac
}

regex_escape() {
    local value="${1}"

    printf '%s\n' "${value}" | sed -e 's/[][(){}.^$*+?|\\/]/\\&/g'
}

parse_definition() {
    local definition="${1}"
    local index="${2}"
    local line key value id host port normalized_mode
    local cfg_group="" cfg_name="" cfg_mode="" cfg_local="" cfg_remote="" cfg_server=""
    local cfg_ssh_port="" cfg_jump="" cfg_key="" cfg_ssh_options="" cfg_description=""

    while IFS= read -r line; do
        line="$(trim "${line}")"
        [[ -z "${line}" || "${line}" == \#* ]] && continue
        [[ "${line}" != *=* ]] && continue

        key="$(trim "${line%%=*}")"
        value="$(trim "${line#*=}")"
        case "${key}" in
            group) cfg_group="${value}" ;;
            name) cfg_name="${value}" ;;
            mode) cfg_mode="${value}" ;;
            local) cfg_local="${value}" ;;
            remote) cfg_remote="${value}" ;;
            server) cfg_server="${value}" ;;
            ssh_port) cfg_ssh_port="${value}" ;;
            jump) cfg_jump="${value}" ;;
            key) cfg_key="${value}" ;;
            ssh_options) cfg_ssh_options="${value}" ;;
            description) cfg_description="${value}" ;;
        esac
    done <<< "${definition}"

    cfg_mode="${cfg_mode:-local}"
    normalized_mode="$(normalize_mode "${cfg_mode}")" || {
        echo "Error: invalid mode '${cfg_mode}' in tunnel definition #${index}." >&2
        return 1
    }
    cfg_mode="${normalized_mode}"

    if [[ -z "${cfg_group}" || -z "${cfg_name}" ]]; then
        echo "Error: tunnel definition #${index} must set group and name." >&2
        return 1
    fi

    if [[ -z "${cfg_server}" ]]; then
        echo "Error: tunnel '${cfg_group}:${cfg_name}' must set server." >&2
        return 1
    fi

    if [[ -z "${cfg_local}" ]]; then
        echo "Error: tunnel '${cfg_group}:${cfg_name}' must set local." >&2
        return 1
    fi

    if [[ "${cfg_mode}" != "socks-proxy" && -z "${cfg_remote}" ]]; then
        echo "Error: tunnel '${cfg_group}:${cfg_name}' must set remote for ${cfg_mode} mode." >&2
        return 1
    fi

    IFS=':' read -r host port <<< "${cfg_server}"
    if [[ -z "${host}" ]]; then
        echo "Error: tunnel '${cfg_group}:${cfg_name}' has an invalid server value." >&2
        return 1
    fi
    cfg_server="${host}"
    cfg_ssh_port="${cfg_ssh_port:-${port}}"

    cfg_key="${cfg_key:-${GLOBAL_SSH_KEY}}"
    cfg_jump="${cfg_jump:-${GLOBAL_SSH_JUMP}}"
    [[ -n "${cfg_key}" ]] && cfg_key="$(expand_path "${cfg_key}")"

    id="${#TUNNEL_IDS[@]}"
    TUNNEL_IDS+=("${id}")
    TUNNEL_GROUP["${id}"]="${cfg_group}"
    TUNNEL_NAME["${id}"]="${cfg_name}"
    TUNNEL_MODE["${id}"]="${cfg_mode}"
    TUNNEL_LOCAL["${id}"]="${cfg_local}"
    TUNNEL_REMOTE["${id}"]="${cfg_remote}"
    TUNNEL_SERVER["${id}"]="${cfg_server}"
    TUNNEL_SSH_PORT["${id}"]="${cfg_ssh_port}"
    TUNNEL_JUMP["${id}"]="${cfg_jump}"
    TUNNEL_KEY["${id}"]="${cfg_key}"
    TUNNEL_SSH_OPTIONS["${id}"]="${cfg_ssh_options}"
    TUNNEL_DESCRIPTION["${id}"]="${cfg_description}"
}

load_tunnel_definitions() {
    local index

    for ((index = 0; index < ${#TUNNEL_DEFINITIONS[@]}; index++)); do
        parse_definition "${TUNNEL_DEFINITIONS[${index}]}" "$((index + 1))" || return 1
    done
}

get_groups() {
    local id

    for id in "${TUNNEL_IDS[@]}"; do
        printf '%s\n' "${TUNNEL_GROUP[${id}]}"
    done | sort -u
}

group_exists() {
    local requested="${1}"
    local group

    [[ "${requested}" == "all" ]] && return 0

    while IFS= read -r group; do
        [[ "${group}" == "${requested}" ]] && return 0
    done < <(get_groups)

    return 1
}

print_available_groups() {
    local group

    printf 'Available groups: all'
    while IFS= read -r group; do
        printf ', %s' "${group}"
    done < <(get_groups)
    printf '\n'
}

tunnel_matches_group() {
    local id="${1}"
    local group="${2}"

    [[ "${group}" == "all" || "${TUNNEL_GROUP[${id}]}" == "${group}" ]]
}

build_autossh_command() {
    local id="${1}"
    local option mode

    BUILT_AUTOSSH_COMMAND=("autossh")
    BUILT_AUTOSSH_COMMAND+=("${GLOBAL_AUTOSSH_OPTIONS[@]}")
    BUILT_AUTOSSH_COMMAND+=("${GLOBAL_SSH_OPTIONS[@]}")

    if [[ -n "${TUNNEL_SSH_OPTIONS[${id}]}" ]]; then
        # shellcheck disable=SC2206
        local extra_options=(${TUNNEL_SSH_OPTIONS[${id}]})
        BUILT_AUTOSSH_COMMAND+=("${extra_options[@]}")
    fi

    mode="${TUNNEL_MODE[${id}]}"
    case "${mode}" in
        local-forward)
            BUILT_AUTOSSH_COMMAND+=("-L" "${TUNNEL_LOCAL[${id}]}:${TUNNEL_REMOTE[${id}]}")
            ;;
        remote-forward)
            BUILT_AUTOSSH_COMMAND+=("-R" "${TUNNEL_REMOTE[${id}]}:${TUNNEL_LOCAL[${id}]}")
            ;;
        socks-proxy)
            BUILT_AUTOSSH_COMMAND+=("-D" "${TUNNEL_LOCAL[${id}]}")
            ;;
    esac

    [[ -n "${TUNNEL_KEY[${id}]}" ]] && BUILT_AUTOSSH_COMMAND+=("-i" "${TUNNEL_KEY[${id}]}")
    [[ -n "${TUNNEL_SSH_PORT[${id}]}" ]] && BUILT_AUTOSSH_COMMAND+=("-p" "${TUNNEL_SSH_PORT[${id}]}")
    [[ -n "${TUNNEL_JUMP[${id}]}" ]] && BUILT_AUTOSSH_COMMAND+=("-J" "${TUNNEL_JUMP[${id}]}")

    BUILT_AUTOSSH_COMMAND+=("${TUNNEL_SERVER[${id}]}")

    for option in "${BUILT_AUTOSSH_COMMAND[@]}"; do
        [[ -n "${option}" ]] || return 1
    done
}

build_process_pattern() {
    local id="${1}"
    local mode="${TUNNEL_MODE[${id}]}"
    local pattern="autossh"

    case "${mode}" in
        local-forward)
            pattern+=" .*-L $(regex_escape "${TUNNEL_LOCAL[${id}]}:${TUNNEL_REMOTE[${id}]}")"
            ;;
        remote-forward)
            pattern+=" .*-R $(regex_escape "${TUNNEL_REMOTE[${id}]}:${TUNNEL_LOCAL[${id}]}")"
            ;;
        socks-proxy)
            pattern+=" .*-D $(regex_escape "${TUNNEL_LOCAL[${id}]}")"
            ;;
    esac

    [[ -n "${TUNNEL_KEY[${id}]}" ]] && pattern+=" .*-i $(regex_escape "${TUNNEL_KEY[${id}]}")"
    [[ -n "${TUNNEL_SSH_PORT[${id}]}" ]] && pattern+=" .*-p $(regex_escape "${TUNNEL_SSH_PORT[${id}]}")"
    [[ -n "${TUNNEL_JUMP[${id}]}" ]] && pattern+=" .*-J $(regex_escape "${TUNNEL_JUMP[${id}]}")"
    pattern+=" .*$(regex_escape "${TUNNEL_SERVER[${id}]}")"

    printf '%s\n' "${pattern}"
}

is_tunnel_running() {
    local id="${1}"
    local pattern

    pattern="$(build_process_pattern "${id}")"
    pgrep -f "${pattern}" >/dev/null 2>&1
}

repeat_char() {
    local char="${1}"
    local count="${2}"
    local line=""

    while (( count > 0 )); do
        line+="${char}"
        ((count--))
    done

    printf '%s\n' "${line}"
}

print_section() {
    local title="${1}"

    printf '%s\n' "${title}"
    repeat_char "-" "${#title}"
}

tunnel_endpoint() {
    local id="${1}"
    local mode="${TUNNEL_MODE[${id}]}"

    case "${mode}" in
        local-forward)
            printf '%s -> %s\n' "${TUNNEL_LOCAL[${id}]}" "${TUNNEL_REMOTE[${id}]}"
            ;;
        remote-forward)
            printf '%s <- %s\n' "${TUNNEL_REMOTE[${id}]}" "${TUNNEL_LOCAL[${id}]}"
            ;;
        socks-proxy)
            printf '%s\n' "${TUNNEL_LOCAL[${id}]}"
            ;;
    esac
}

tunnel_server_label() {
    local id="${1}"
    local server="${TUNNEL_SERVER[${id}]}"

    if [[ -n "${TUNNEL_SSH_PORT[${id}]}" ]]; then
        server+=":${TUNNEL_SSH_PORT[${id}]}"
    fi

    printf '%s\n' "${server}"
}

tunnel_label() {
    local id="${1}"

    printf '%s/%s' "${TUNNEL_GROUP[${id}]}" "${TUNNEL_NAME[${id}]}"
}

print_action_message() {
    local action="${1}"
    local id="${2}"
    local message="${3}"

    printf "%-10s %-24s %-16s %-28s via %s\n" \
        "${action}" \
        "$(tunnel_label "${id}")" \
        "$(mode_label "${TUNNEL_MODE[${id}]}")" \
        "$(tunnel_endpoint "${id}")" \
        "$(tunnel_server_label "${id}")"

    [[ -n "${message}" ]] && printf "           %s\n" "${message}"
}

print_status_header() {
    printf "%-10s %-12s %-22s %-16s %-18s %-24s %-18s %s\n" \
        "STATE" "GROUP" "NAME" "MODE" "LOCAL" "REMOTE" "SSH SERVER" "DESCRIPTION"
    repeat_char "-" 144
}

print_tunnel_status() {
    local id="${1}"
    local status="${2}"

    printf "%-10s %-12s %-22s %-16s %-18s %-24s %-18s %s\n" \
        "${status}" \
        "${TUNNEL_GROUP[${id}]}" \
        "${TUNNEL_NAME[${id}]}" \
        "$(mode_label "${TUNNEL_MODE[${id}]}")" \
        "${TUNNEL_LOCAL[${id}]}" \
        "${TUNNEL_REMOTE[${id}]:-N/A}" \
        "$(tunnel_server_label "${id}")" \
        "${TUNNEL_DESCRIPTION[${id}]}"
}

print_tunnel_list() {
    local id description

    printf "%-12s %-22s %-16s %-18s %-24s %-18s %s\n" \
        "GROUP" "NAME" "MODE" "LOCAL" "REMOTE" "SSH SERVER" "DESCRIPTION"
    repeat_char "-" 139

    for id in "${TUNNEL_IDS[@]}"; do
        description="${TUNNEL_DESCRIPTION[${id}]}"
        printf "%-12s %-22s %-16s %-18s %-24s %-18s %s\n" \
            "${TUNNEL_GROUP[${id}]}" \
            "${TUNNEL_NAME[${id}]}" \
            "$(mode_label "${TUNNEL_MODE[${id}]}")" \
            "${TUNNEL_LOCAL[${id}]}" \
            "${TUNNEL_REMOTE[${id}]:-N/A}" \
            "$(tunnel_server_label "${id}")" \
            "${description}"
    done
}

show_usage() {
    local group

    cat << EOF
autossh-manager v${SCRIPT_VERSION}

Usage:
  ${SCRIPT_NAME} {start|stop|restart|status} [group]
  ${SCRIPT_NAME} list
  ${SCRIPT_NAME} help

Groups:
  all
EOF

    while IFS= read -r group; do
        printf '  %s\n' "${group}"
    done < <(get_groups)

    printf '\n'
    print_section "Configured Tunnels"
    print_tunnel_list

    cat << 'EOF'

Configuration Fields:
  group        Group name used by commands.
  name         Display name for the tunnel.
  mode         local-forward, remote-forward, or socks-proxy.
               Short aliases local/L, remote/R, and dynamic/D are also accepted.
  local        Local endpoint, for example :22022.
  remote       Remote endpoint. Required for local-forward and remote-forward.
  server       SSH server, optionally server:port.
  ssh_port     SSH port override.
  jump         SSH jump host, equivalent to ssh -J.
  key          SSH identity file, equivalent to ssh -i.
  ssh_options  Extra SSH options split on spaces.
  description  Note shown in this help output.

Mode Meanings:
  local-forward   ssh -L. Listen locally and forward traffic through SSH to
                  the remote-side destination.
  remote-forward  ssh -R. Listen on the SSH server side and forward traffic
                  back through SSH to the local-side destination.
  socks-proxy     ssh -D. Listen locally as a SOCKS4/5 proxy and choose the
                  target dynamically per connection.
EOF
}

    case "${action}" in
        start)
            if is_tunnel_running "${id}"; then
                print_action_message "running" "${id}" "Tunnel is already active."
                return 0
            fi

# ==============================================================================
# Business Logic
# ==============================================================================

manage_tunnel() {
    local action="${1}"
    local id="${2}"

    case "${action}" in
        start)
            if is_tunnel_running "${id}"; then
                print_action_message "running" "${id}" "Tunnel is already active."
                return 0
            fi

            build_autossh_command "${id}" || return 1
            print_action_message "starting" "${id}" ""
            if "${BUILT_AUTOSSH_COMMAND[@]}"; then
                print_action_message "started" "${id}" ""
                return 0
            fi

            print_action_message "failed" "${id}" "autossh exited with an error."
            return 1
            ;;
        stop)
            if ! is_tunnel_running "${id}"; then
                print_action_message "stopped" "${id}" "Tunnel is not running."
                return 0
            fi

            print_action_message "stopping" "${id}" ""
            if pkill -f "$(build_process_pattern "${id}")" 2>/dev/null; then
                print_action_message "stopped" "${id}" ""
                return 0
            fi

            print_action_message "failed" "${id}" "Could not stop matching autossh process."
            return 1
            ;;
        status)
            if is_tunnel_running "${id}"; then
                print_tunnel_status "${id}" "running"
                return 0
            fi

            print_tunnel_status "${id}" "stopped"
            return 0
            ;;
        *)
            echo "Error: unsupported action '${action}'." >&2
            return 1
            ;;
    esac
}

process_group() {
    local action="${1}"
    local group="${2}"
    local id failed=0 matched=0

    if ! group_exists "${group}"; then
        echo "Error: invalid group '${group}'." >&2
        print_available_groups >&2
        return 1
    fi

    print_section "autossh-manager: ${action} (${group})"
    if [[ "${action}" == "status" ]]; then
        print_status_header
    fi

    for id in "${TUNNEL_IDS[@]}"; do
        tunnel_matches_group "${id}" "${group}" || continue
        matched=1
        if ! manage_tunnel "${action}" "${id}"; then
            failed=1
        fi
    done

    [[ "${matched}" -eq 1 ]] || {
        echo "No tunnels matched group '${group}'." >&2
        return 1
    }

    return "${failed}"
}

main() {
    local action="${1:-help}"
    local group="${2:-all}"
    local failed=0

    load_tunnel_definitions || exit 1

    case "${action}" in
        start|stop|status)
            process_group "${action}" "${group}"
            ;;
        restart)
            process_group "stop" "${group}" || failed=1
            process_group "start" "${group}" || failed=1
            return "${failed}"
            ;;
        list)
            print_tunnel_list
            ;;
        help|-h|--help)
            show_usage
            ;;
        *)
            show_usage
            exit 1
            ;;
    esac
}

main "$@"
