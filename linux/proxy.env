proxy_on() {
    # export HOST_IP=`ip route show | grep -i default | awk '{print $3}'` # for WSL
    
    PROXY_HOST=${HOST_IP}
    PROXY_PORT=7890

    export http_proxy=http://${PROXY_HOST}:${PROXY_PORT}
    export socks_proxy=socks://${PROXY_HOST}:${PROXY_PORT}

    export all_proxy=${http_proxy}
    export https_proxy=${http_proxy}
    export no_proxy="localhost,*.local,127.0.0.1,10.*.*.*,192.168.*.*"

    export ALL_PROXY=${all_proxy}
    export HTTP_PROXY=${http_proxy}
    export HTTPS_PROXY=${https_proxy}
    export SOCKS_PROXY=${socks_proxy}
    export NO_PROXY=${no_proxy}

    env | grep -i _proxy
}

proxy_off() {
    unset all_proxy http_proxy https_proxy socks_proxy no_proxy
    unset ALL_PROXY HTTP_PROXY HTTPS_PROXY SOCKS_PROXY NO_PROXY
}

